DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
APP_URL=http://localhost:5000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace-with-generated-password-hash
# Chỉ dùng khi chạy dev local. Production nên dùng ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD=replace-with-local-dev-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
FIELD_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# Tuỳ chọn. Mặc định ảnh được lưu ở .data/uploads/rooms.
ROOM_UPLOAD_DIR=.data/uploads/rooms
